<?xml version="1.0" encoding="UTF-8"?>

<RelativeLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/newaliaslayout"
  android:layout_width="match_parent"
  android:layout_height="match_parent">
  
  <TextView
		android:id="@+id/titlebar"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_alignParentTop="true"
		android:text="NEW ALIAS"
		android:textColor="#FF333333"
		android:background="#FF999999"
		android:textSize="15dip"
		android:textStyle="bold"
		android:gravity="center"/>

  <LinearLayout
  	android:id="@+id/editor_button_bar"
  	android:layout_width="match_parent"
  	android:layout_height="wrap_content"
  	android:layout_alignParentBottom="true"
  	android:orientation="horizontal"
  	android:gravity="center">
	  <Button
	    android:layout_width="0dip"
	  	android:layout_height="wrap_content"
	  	android:layout_weight="1"
	  	android:id="@+id/new_alias_cancel"
	  	android:text="Cancel" />
	  <Button
	  	android:layout_width="0dip"
	  	android:layout_height="wrap_content"
	  	android:layout_weight="1"
	  	android:text="Done"
	  	android:id="@+id/new_alias_done_button"/>
  </LinearLayout>
  
  <ScrollView 
  	android:layout_width="match_parent"
  	android:layout_height="match_parent"
  	android:layout_above="@id/editor_button_bar"
  	android:layout_below="@id/titlebar"
  	android:fillViewport="true">
  	<LinearLayout
  		android:layout_width="match_parent"
  		android:layout_height="wrap_content"
  		android:orientation="vertical"
  		android:paddingLeft="8dip"
  		android:paddingRight="8dip">
  <TableLayout
  	android:layout_width="match_parent"
  	android:layout_height="wrap_content"
  	android:stretchColumns="1"
  	android:shrinkColumns="1"
  	android:id="@+id/alias_label">

  	<TableRow>
  		<TextView 
  			android:layout_width="wrap_content"
  			android:layout_height="wrap_content"
 			android:text = "Replace:"
 			android:gravity="right"
 			android:layout_marginRight="5dip"/>
  		<EditText
  			android:id = "@+id/new_alias_pre"
  			android:layout_width="0dip"
  			android:layout_weight="1"
  			android:singleLine = "true"
  			android:layout_height="wrap_content"
  			android:fontFamily="monospace"
  			android:hint="Text to replace." />
  	
  	</TableRow>
  	<TableRow>
  		<TextView 
  			android:layout_width="wrap_content"
  			android:layout_height="wrap_content"
 			android:text = "With:"
 			android:gravity="right"
 			android:layout_marginRight="5dip"/>
  		<EditText
  			android:id="@+id/new_alias_post"
  			android:layout_width="0dip"
  			android:layout_weight="1"
  			android:layout_height="wrap_content"
  			android:fontFamily="monospace"
  			android:inputType="textMultiLine"
  			android:minLines="2"
  			android:maxLines="6"
  			android:hint="Replace with this." />
  	
  	</TableRow>
  	<TableRow>
  		<TextView
  			android:layout_width="wrap_content"
  			android:layout_height="wrap_content"
 			android:text="Preview:"
 			android:gravity="right"
 			android:layout_marginRight="5dip"/>
  		<TextView
  			android:id="@+id/alias_send_preview"
  			android:layout_width="0dip"
  			android:layout_weight="1"
  			android:layout_height="wrap_content"
  			android:textColor="#FFE8E8E8"
  			android:textSize="13sp"
  			android:fontFamily="monospace"
  			android:background="#FF1A1A1A"
  			android:padding="6dip"
  			android:text="Type a pattern to preview what is sent to the server." />
  	</TableRow>
  	
  </TableLayout>
  <RelativeLayout
  			android:layout_width="match_parent"
  			android:layout_height="wrap_content"
  			android:layout_marginTop="5dip"
  			>
  			
  				<CheckBox 
  					android:id="@+id/carrot" 
  					android:layout_alignParentLeft="true" 
  					android:layout_alignParentRight="true"
  					android:layout_alignParentTop="true" 
  					android:layout_marginLeft="30dip" 
  					android:layout_width="wrap_content" 
  					android:layout_height="wrap_content" 
  					android:textStyle="bold"
  					android:textSize="15dip"
  					android:text="Matches start of Line (^)"
  					android:layout_marginRight="30dip" 
  					android:checked="false"/>
  				<CheckBox 
  					android:id="@+id/dollar" 
  					android:layout_alignParentLeft="true" 
  					android:layout_alignParentRight="true"
  					android:layout_below="@id/carrot"
  					android:layout_marginRight="30dip" 
  					android:layout_marginLeft="30dip" 
  					android:layout_width="wrap_content" 
  					android:layout_height="wrap_content" 
  					android:textStyle="bold"
  					android:textSize="15dip"
  					android:text="Matches end of line ($)"
  					android:checked="false"/>
  				<CheckBox
  				  	android:id="@+id/enabledcheck" 
  					android:layout_alignParentLeft="true" 
  					android:layout_alignParentRight="true"
  					android:layout_below="@id/dollar"
  					android:layout_marginRight="30dip" 
  					android:layout_marginLeft="30dip" 
  					android:layout_width="wrap_content" 
  					android:layout_height="wrap_content" 
  					android:textStyle="bold"
  					android:textSize="15dip"
  					android:text="Enabled"
  					android:checked="true"/>
  			
  		</RelativeLayout>
  </LinearLayout>
  </ScrollView>

  
</RelativeLayout>
