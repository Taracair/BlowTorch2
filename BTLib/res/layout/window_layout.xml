<?xml version="1.0" encoding="UTF-8"?>

<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <RelativeLayout
        android:id="@+id/window_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent">

        <LinearLayout
            android:id="@+id/inputbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:orientation="vertical"
            android:background="@color/game_input_bg">

            <!-- Top edge of the input chrome (not a floating sibling over game text). -->
            <View
                android:id="@+id/divider"
                android:layout_width="match_parent"
                android:layout_height="3dip"
                android:background="@color/game_divider" />

            <!-- Inside inputbar so windows laid out above the divider clear the search UI. -->
            <include layout="@layout/scrollback_search_bar" />

            <include layout="@layout/input_edit_tools" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom"
                android:paddingLeft="4dip"
                android:paddingRight="2dip"
                android:paddingTop="0dip"
                android:paddingBottom="0dip">

            <com.resurrection.blowtorch2.lib.window.BetterEditText
                android:id="@+id/textinput"
                android:layout_width="0dip"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/input_bar_bg"
                android:candidatesTextStyleSpans=""
                android:editable="true"
                android:imeOptions="actionSend"
                android:isScrollContainer="false"
                android:keepScreenOn="true"
                android:maxLines="18"
                android:minHeight="28dip"
                android:paddingTop="2dip"
                android:paddingBottom="2dip"
                android:nextFocusDown="@id/textinput"
                android:nextFocusLeft="@id/textinput"
                android:nextFocusRight="@id/textinput"
                android:nextFocusUp="@id/textinput"
                android:scrollHorizontally="false"
                android:textColor="@color/game_input_text"
                android:textColorHighlight="@color/game_input_highlight"
                android:textSize="16sp"
                android:typeface="monospace" />

            <LinearLayout
                android:id="@+id/input_action_buttons"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="bottom|end"
                android:layout_gravity="bottom"
                android:layout_marginLeft="4dip"
                android:layout_marginRight="2dip">

                <Button
                    android:id="@+id/input_edit_toggle"
                    style="@style/InputEditToolButton"
                    android:layout_width="wrap_content"
                    android:layout_height="28dip"
                    android:minHeight="28dip"
                    android:minWidth="48dip"
                    android:layout_marginBottom="2dip"
                    android:text="Edit"
                    android:contentDescription="Toggle edit tools" />

                <Button
                    android:id="@+id/input_send"
                    style="@style/InputEditToolButton"
                    android:layout_width="wrap_content"
                    android:layout_height="28dip"
                    android:minHeight="28dip"
                    android:minWidth="48dip"
                    android:text="Send"
                    android:contentDescription="Send input" />
            </LinearLayout>
            </LinearLayout>

        </LinearLayout>

        <com.resurrection.blowtorch2.lib.window.NoTouchActionBar
            android:id="@+id/my_toolbar"
            style="@style/BlowTorch.Game.Toolbar"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_above="@id/inputbar"
            android:clickable="false"
            android:focusable="false"
            android:visibility="gone"
            app:backgroundTint="@null"
            app:contentInsetEnd="0dp"
            app:contentInsetLeft="0dp"
            app:contentInsetRight="0dp"
            app:contentInsetStart="0dp"
            app:popupTheme="@style/ThemeOverlay.AppCompat.Dark" />

    </RelativeLayout>

    <FrameLayout
        android:id="@+id/gameplay_chrome_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- ⋮ lives in the overlay so full-screen game windows cannot cover it. -->
        <include layout="@layout/gameplay_fab_strip" />

    </FrameLayout>

</FrameLayout>
