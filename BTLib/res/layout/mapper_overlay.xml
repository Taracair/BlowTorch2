<?xml version="1.0" encoding="utf-8"?>
<!-- Floating / fullscreen mapper chrome. Attached under window_container so
     gameplay_chrome_overlay (⋮) stays above via z-order (do NOT pad away title buttons). -->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mapper_overlay_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC1A1A1A"
    android:clickable="true"
    android:focusable="true"
    android:paddingTop="8dp"
    android:paddingEnd="8dp"
    android:paddingRight="8dp"
    android:paddingBottom="4dp"
    android:paddingStart="4dp"
    android:paddingLeft="4dp">

    <LinearLayout
        android:id="@+id/mapper_title_bar"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_alignParentTop="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="4dp"
        android:paddingRight="4dp"
        android:background="#AA000000">

        <TextView
            android:id="@+id/mapper_drag_handle"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:paddingLeft="4dp"
            android:paddingRight="8dp"
            android:text="☰"
            android:textColor="#CCCCCC"
            android:textSize="16sp"
            android:contentDescription="Drag map window" />

        <TextView
            android:id="@+id/mapper_title"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:text="Map"
            android:textColor="#EEEEEE"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/mapper_mode_btn"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:text="Float"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:background="#44FFFFFF"
            android:contentDescription="Toggle float or fullscreen" />

        <TextView
            android:id="@+id/mapper_close_btn"
            android:layout_width="40dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="✕"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:background="#44FFFFFF"
            android:contentDescription="Close map" />
    </LinearLayout>

    <HorizontalScrollView
        android:id="@+id/mapper_toolbar_scroll"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_alignParentBottom="true"
        android:background="#AA000000"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/mapper_toolbar"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingLeft="4dp"
            android:paddingRight="4dp" />
    </HorizontalScrollView>

    <FrameLayout
        android:id="@+id/mapper_map_holder"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/mapper_toolbar_scroll"
        android:layout_below="@id/mapper_title_bar">

        <com.resurrection.blowtorch2.lib.mapper.MapperView
            android:id="@+id/mapper_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <TextView
            android:id="@+id/mapper_resize_handle"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="bottom|end"
            android:gravity="center"
            android:text="◢"
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:background="#66000000"
            android:contentDescription="Resize map window" />
    </FrameLayout>

</RelativeLayout>
