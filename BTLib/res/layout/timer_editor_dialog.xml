<?xml version="1.0" encoding="UTF-8"?>

<RelativeLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/newtriggerlayout"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:layout_marginLeft="4dip"
  android:layout_marginRight="4dip">
  
  <TextView
		android:id="@+id/titlebar"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_alignParentTop="true"
		android:text="TIMER EDITOR"
		android:textColor="#FF333333"
		android:background="#FF999999"
		android:textSize="15dip"
		android:textStyle="bold"
		android:gravity="center"/>

  <LinearLayout
  	android:id="@+id/editor_button_bar"
  	android:layout_width="match_parent"
  	android:layout_height="wrap_content"
  	android:layout_alignParentBottom="true"
  	android:orientation="horizontal"
  	android:gravity="center">
	  <Button
	    android:layout_width="0dip"
	  	android:layout_height="wrap_content"
	  	android:layout_weight="1"
	  	android:id="@+id/timer_editor_cancel"
	  	android:text="Cancel" />
	  <Button
	  	android:layout_width="0dip"
	  	android:layout_height="wrap_content"
	  	android:layout_weight="1"
	  	android:text="Done"
	  	android:id="@+id/timer_editor_done_button"/>
  </LinearLayout>
  
  <ScrollView
  	android:layout_width="match_parent"
  	android:layout_height="match_parent"
  	android:layout_above="@id/editor_button_bar"
  	android:layout_below="@id/titlebar"
  	android:fillViewport="true"
  	android:id="@+id/timer_editor_scroll_container">
  	<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
  		<TableLayout android:layout_width="match_parent" android:layout_height="wrap_content"  android:stretchColumns="1">
  			<TableRow>
  				<TextView
  					android:text="Name:"
  					android:layout_marginLeft="10dip"
  					android:layout_marginRight="5dip"
  					android:layout_width="wrap_content"
  					android:gravity="right"/>
  				<EditText
  					android:id="@+id/timer_editor_name"
  					android:layout_marginRight="10dip"
  					android:layout_width="0dip"
  					android:layout_weight="1"
  					android:singleLine="true"
  					android:hint="Timer Function"
  					android:inputType="text"/>
  			</TableRow>
  			<TableRow>
  				<TextView
  					android:text="Group:"
  					android:layout_marginLeft="10dip"
  					android:layout_marginRight="5dip"
  					android:layout_width="wrap_content"
  					android:gravity="right"/>
  				<LinearLayout
  					android:layout_width="0dip"
  					android:layout_height="wrap_content"
  					android:layout_weight="1"
  					android:layout_marginRight="10dip"
  					android:orientation="vertical">
					<Spinner
						android:id="@+id/timer_editor_group_spinner"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:minHeight="44dip"
						android:popupBackground="#FF000000"/>
  					<AutoCompleteTextView
  						android:id="@+id/timer_editor_group"
  						android:layout_width="match_parent"
  						android:layout_height="wrap_content"
  						android:singleLine="true"
  						android:hint="or type a new group"
  						android:completionThreshold="1"
  						android:inputType="text"/>
  				</LinearLayout>
  			</TableRow>
  		</TableLayout>
  		<LinearLayout
  			android:layout_width="match_parent"
  			android:layout_height="wrap_content"
  			android:orientation="horizontal"
  			android:gravity="center_vertical"
  			android:layout_marginLeft="10dip"
  			android:layout_marginRight="10dip"
  			android:layout_marginTop="6dip"
  			android:layout_marginBottom="10dip"
  			android:paddingTop="4dip"
  			android:paddingBottom="4dip">
  			<TextView
  				android:text="Seconds:"
  				android:layout_marginRight="8dip"
  				android:layout_width="wrap_content"
  				android:layout_height="wrap_content"
  				android:gravity="center_vertical"/>
  			<EditText
  				android:id="@+id/timer_editor_seconds"
  				android:layout_width="96dip"
  				android:layout_height="wrap_content"
  				android:minHeight="48dip"
  				android:paddingTop="10dip"
  				android:paddingBottom="10dip"
  				android:gravity="center_vertical"
  				android:singleLine="true"
  				android:hint="30"
  				android:inputType="number"/>
  			<CheckBox
  				android:id="@+id/timer_repeat_checkbox"
  				android:text="Repeat?"
  				android:textSize="13sp"
  				android:layout_marginLeft="16dip"
  				android:layout_width="wrap_content"
  				android:layout_height="wrap_content"
  				android:layout_gravity="center_vertical"/>
  		</LinearLayout>
  		<TextView android:layout_width="match_parent"
  					android:layout_height="wrap_content"
  					android:text="EXECUTE ACTIONS"
  					android:layout_marginLeft="10dip"
  					android:layout_marginRight="10dip"
  					android:background="#FF999999"
  					android:gravity="center"
  					android:textStyle="bold"
  					android:textColor="#FF111111"/>
  		<TableLayout
  			android:id="@+id/timer_notification_table"
  			android:layout_width="match_parent"
  			android:layout_height="wrap_content"
  			android:layout_marginLeft="10dip"
  			android:layout_marginRight="10dip"
  			android:stretchColumns="0"
  			android:shrinkColumns="0"
  			android:background="@drawable/movemethod_frame">
  			<TableRow android:id="@+id/timer_notification_legend">
  				<TextView
  					android:text="TYPE"
  					android:gravity="center"
  					/>
  				<TextView
  					android:text="Window\nOpen"
  					android:gravity="center"
  					android:layout_marginRight="3dip" android:layout_marginLeft="3dip"/>
  				<TextView
  					android:text="Window\nClosed"
  					android:gravity="center"
  					android:layout_marginRight="3dip" android:layout_marginLeft="3dip"/>
  				<TextView
  					android:text="Del"
  					android:id="@+id/timer_delete_responder"
  					android:gravity="center"
  					android:layout_marginRight="1dip" android:layout_marginLeft="1dip"/>
  			</TableRow>
  			<TableRow android:id="@+id/timer_new_responder_row">
  				<Button android:id="@+id/timer_new_notification" android:text="New Action" android:paddingLeft="10dip" android:paddingRight="10dip"/>
  				<TextView android:text=""/>
  				<TextView android:text=""/>
  			</TableRow>
  		</TableLayout>
  	</LinearLayout>
  	
  </ScrollView>

  
</RelativeLayout>
