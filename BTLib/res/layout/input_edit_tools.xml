<?xml version="1.0" encoding="utf-8"?>
<!-- Full-width Edit strip: equal-weight buttons, no leftover gap. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/input_edit_tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:visibility="gone"
    android:paddingLeft="2dip"
    android:paddingRight="2dip"
    android:paddingTop="2dip"
    android:paddingBottom="2dip"
    android:background="#FF1A1A1A">

    <Button
        android:id="@+id/input_btn_select"
        style="@style/InputEditToolButton.Compact"
        android:layout_width="0dip"
        android:layout_weight="1"
        android:text="Sel" />
    <Button
        android:id="@+id/input_btn_cut"
        style="@style/InputEditToolButton.Compact"
        android:layout_width="0dip"
        android:layout_weight="1"
        android:text="Cut" />
    <Button
        android:id="@+id/input_btn_copy"
        style="@style/InputEditToolButton.Compact"
        android:layout_width="0dip"
        android:layout_weight="1"
        android:text="Copy" />
    <Button
        android:id="@+id/input_btn_paste"
        style="@style/InputEditToolButton.Compact"
        android:layout_width="0dip"
        android:layout_weight="1"
        android:text="Paste" />

    <View
        android:layout_width="1dip"
        android:layout_height="18dip"
        android:layout_marginLeft="1dip"
        android:layout_marginRight="1dip"
        android:background="#44FFFFFF" />

    <Button
        android:id="@+id/input_btn_home"
        style="@style/InputEditToolButton.Compact"
        android:layout_width="0dip"
        android:layout_weight="1"
        android:text="|&lt;"
        android:contentDescription="Cursor start" />
    <Button
        android:id="@+id/input_btn_left"
        style="@style/InputEditToolButton.Compact"
        android:layout_width="0dip"
        android:layout_weight="1"
        android:text="←"
        android:contentDescription="Cursor left" />
    <Button
        android:id="@+id/input_btn_up"
        style="@style/InputEditToolButton.Compact"
        android:layout_width="0dip"
        android:layout_weight="1"
        android:text="↑"
        android:contentDescription="Cursor up" />
    <Button
        android:id="@+id/input_btn_down"
        style="@style/InputEditToolButton.Compact"
        android:layout_width="0dip"
        android:layout_weight="1"
        android:text="↓"
        android:contentDescription="Cursor down" />
    <Button
        android:id="@+id/input_btn_right"
        style="@style/InputEditToolButton.Compact"
        android:layout_width="0dip"
        android:layout_weight="1"
        android:text="→"
        android:contentDescription="Cursor right" />
    <Button
        android:id="@+id/input_btn_end"
        style="@style/InputEditToolButton.Compact"
        android:layout_width="0dip"
        android:layout_weight="1"
        android:text="&gt;|"
        android:contentDescription="Cursor end" />
</LinearLayout>
