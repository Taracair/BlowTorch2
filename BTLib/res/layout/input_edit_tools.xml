<?xml version="1.0" encoding="utf-8"?>
<!-- Edit strip: clipboard row + compact cursor pad (shown only when Edit is expanded). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/input_edit_tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:visibility="gone"
    android:background="#FF1A1A1A">

    <HorizontalScrollView
        android:id="@+id/input_edit_strip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:fillViewport="false">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingLeft="4dip"
            android:paddingRight="4dip"
            android:paddingTop="2dip"
            android:paddingBottom="2dip">

            <Button
                android:id="@+id/input_btn_select"
                style="@style/InputEditToolButton"
                android:text="Sel" />
            <Button
                android:id="@+id/input_btn_cut"
                style="@style/InputEditToolButton"
                android:text="Cut" />
            <Button
                android:id="@+id/input_btn_copy"
                style="@style/InputEditToolButton"
                android:text="Copy" />
            <Button
                android:id="@+id/input_btn_paste"
                style="@style/InputEditToolButton"
                android:text="Paste" />
            <Button
                android:id="@+id/input_btn_home"
                style="@style/InputEditToolButton"
                android:text="|&lt;" />
            <Button
                android:id="@+id/input_btn_end"
                style="@style/InputEditToolButton"
                android:text="&gt;|" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Compact D-pad row: keeps caret tools off the main input line until Edit is open. -->
    <LinearLayout
        android:id="@+id/input_cursor_pad"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingLeft="4dip"
        android:paddingRight="4dip"
        android:paddingTop="0dip"
        android:paddingBottom="2dip">

        <Button
            android:id="@+id/input_btn_left"
            style="@style/InputEditToolButton"
            android:minWidth="44dip"
            android:text="←"
            android:contentDescription="Cursor left" />
        <Button
            android:id="@+id/input_btn_up"
            style="@style/InputEditToolButton"
            android:minWidth="44dip"
            android:text="↑"
            android:contentDescription="Cursor up" />
        <Button
            android:id="@+id/input_btn_down"
            style="@style/InputEditToolButton"
            android:minWidth="44dip"
            android:text="↓"
            android:contentDescription="Cursor down" />
        <Button
            android:id="@+id/input_btn_right"
            style="@style/InputEditToolButton"
            android:minWidth="44dip"
            android:text="→"
            android:contentDescription="Cursor right" />
    </LinearLayout>
</LinearLayout>
