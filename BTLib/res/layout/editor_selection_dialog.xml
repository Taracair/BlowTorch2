<?xml version="1.0" encoding="UTF-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent" >

	<Button
		android:id="@+id/optionsbutton"
		android:layout_width="40dip"
		android:layout_height="40dip"
		android:layout_alignParentTop="true"
		android:layout_alignParentRight="true"
		android:background="@drawable/optionsbutton_selector"
		android:text="="
		android:textSize="20dip"
		android:visibility="gone" />

	<TextView
		android:id="@+id/titlebar"
		android:layout_width="fill_parent"
		android:layout_height="40dip"
		android:layout_alignParentTop="true"
		android:layout_toLeftOf="@id/optionsbutton"
		android:text="SELECT TRIGGER"
		android:textColor="#FF333333"
		android:background="#FF999999"
		android:textSize="15dip"
		android:textStyle="bold"
		android:gravity="center"/>

	<LinearLayout
		android:id="@+id/search_filter_block"
		android:layout_width="fill_parent"
		android:layout_height="wrap_content"
		android:layout_below="@id/titlebar"
		android:orientation="vertical">

		<EditText
			android:id="@+id/search_field"
			android:layout_width="fill_parent"
			android:layout_height="wrap_content"
			android:minHeight="44dip"
			android:hint="Search name or pattern"
			android:inputType="text"
			android:maxLines="1"
			android:imeOptions="actionSearch"
			android:textColor="#FF000000"
			android:textColorHint="#FF666666"
			android:background="#FFCCCCCC"
			android:paddingLeft="10dip"
			android:paddingRight="10dip"
			android:paddingTop="10dip"
			android:paddingBottom="10dip"
			android:textSize="16dip"/>

		<LinearLayout
			android:id="@+id/filter_bar"
			android:layout_width="fill_parent"
			android:layout_height="wrap_content"
			android:orientation="horizontal"
			android:gravity="center_vertical"
			android:background="#FFBBBBBB"
			android:paddingLeft="6dip"
			android:paddingRight="6dip"
			android:paddingTop="4dip"
			android:paddingBottom="4dip"
			android:visibility="gone">

			<Spinner
				android:id="@+id/plugin_filter_spinner"
				android:layout_width="0dip"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:minHeight="40dip"
				android:popupBackground="#FF000000"/>

			<Spinner
				android:id="@+id/group_filter_spinner"
				android:layout_width="0dip"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:minHeight="40dip"
				android:layout_marginLeft="4dip"
				android:popupBackground="#FF000000"
				android:visibility="gone"/>
		</LinearLayout>
	</LinearLayout>

	<Button
		android:id="@+id/done"
		android:layout_alignParentBottom="true"
		android:layout_alignParentRight="true"
		android:layout_height="wrap_content"
		android:minHeight="48dip"
		android:layout_width="120dip"
		android:text="Done"/>

	<Button
		android:id="@+id/refresh"
		android:layout_alignParentBottom="true"
		android:layout_toLeftOf="@id/done"
		android:layout_height="wrap_content"
		android:minHeight="48dip"
		android:layout_width="120dip"
		android:visibility="gone"
		android:text="Refresh"/>

	<Button
		android:id="@+id/add"
		android:layout_alignParentBottom="true"
		android:layout_alignParentLeft="true"
		android:layout_toLeftOf="@id/refresh"
		android:layout_height="wrap_content"
		android:minHeight="48dip"
		android:layout_width="match_parent"
		android:text="New"/>

	<FrameLayout
	    android:id="@+id/frame"
	    android:layout_width="match_parent"
	    android:layout_height="fill_parent"
	    android:layout_above="@id/add"
	    android:layout_below="@id/search_filter_block"
	    android:layout_margin="0dip"
	    android:padding="0dip" >

		<ListView
			android:id="@+id/list"
			android:layout_height="fill_parent"
			android:layout_width="match_parent"/>
		<TextView
			android:id="@+id/empty"
			android:layout_width="match_parent"
			android:layout_height="fill_parent"
			android:text="No items to display."
			android:textColor="#FFFFFFFF"
			android:background="#FF000000"
			android:layout_margin="0dip"
			android:padding="0dip"
			android:textStyle="bold"
			android:textSize="18dip"
			android:gravity="center"/>
	</FrameLayout>

	<ListView
	    android:id="@+id/optionslist"
	    android:layout_width="fill_parent"
	    android:layout_height="wrap_content"
	    android:layout_below="@id/optionsbutton"
	 	android:layout_marginRight="20dip"
	 	android:layout_marginLeft="20dip"
	 	android:divider="@drawable/optionslist_separator"
	 	android:dividerHeight="3dip"
	 	android:background="@drawable/optionslist_border"
	    android:listSelector="@drawable/timer_list_item_selector"
	    android:drawSelectorOnTop="true"
	    android:visibility="invisible"/>

</RelativeLayout>
