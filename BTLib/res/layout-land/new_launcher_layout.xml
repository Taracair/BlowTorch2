<?xml version="1.0" encoding="UTF-8"?>
<RelativeLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:id="@+id/launcher_window_content"
	android:layout_height="match_parent"
	android:layout_width="match_parent">

	<ImageView
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:scaleType="centerCrop"
		android:src="@drawable/background"/>

	<androidx.appcompat.widget.Toolbar
		android:id="@+id/my_toolbar"
		android:layout_width="match_parent"
		android:layout_height="?attr/actionBarSize"
		android:background="?attr/colorPrimary"
		android:elevation="4dp"
		android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
		android:layout_alignParentTop="true"
		app:popupTheme="@style/ThemeOverlay.AppCompat.Dark"/>

	<TextView
		android:id="@+id/c_label"
		android:text="Connections"
		android:textSize="18sp"
		android:textStyle="bold"
		android:layout_height="wrap_content"
		android:layout_width="match_parent"
		android:layout_below="@id/my_toolbar"
		android:gravity="center_vertical"
		android:paddingLeft="16dip"
		android:paddingRight="16dip"
		android:paddingTop="10dip"
		android:paddingBottom="8dip"
		android:textColor="#EEF5F5F5"
		android:background="#66000000"/>

	<LinearLayout
		android:id="@+id/table_container"
		android:layout_height="wrap_content"
		android:layout_width="match_parent"
		android:layout_alignParentBottom="true"
		android:orientation="vertical"
		android:background="#00000000"
		android:paddingLeft="12dip"
		android:paddingRight="12dip"
		android:paddingTop="8dip"
		android:paddingBottom="8dip">

		<LinearLayout
			android:id="@+id/test_update"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical"
			android:visibility="gone">
			<TextView
				android:id="@+id/update_label"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:gravity="center"
				android:paddingTop="4dip"
				android:paddingBottom="4dip"
				android:text="Test"
				android:textSize="14sp"
				android:textColor="#EEF5F5F5"
				android:textStyle="bold"/>
		</LinearLayout>

		<androidx.appcompat.widget.AppCompatButton
			android:id="@+id/new_connection"
			style="@style/LauncherActionButton"
			android:layout_height="wrap_content"
			android:layout_width="match_parent"
			android:text="@string/launcher_btn_new"/>
	</LinearLayout>

	<androidx.appcompat.widget.AppCompatButton
		android:id="@+id/help_button"
		android:layout_width="0dip"
		android:layout_height="0dip"
		android:visibility="gone"/>

	<FrameLayout
		android:id="@+id/timer_frame"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:layout_margin="0dip"
		android:padding="0dip"
		android:layout_above="@id/table_container"
		android:layout_below="@id/c_label">

		<ListView
			android:id="@+id/connection_list"
			android:layout_height="match_parent"
			android:layout_width="match_parent"
			android:divider="#00000000"/>

		<TextView
			android:id="@+id/launcher_empty"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:text="No connections.\nTap New below to add a server."
			android:textColor="#EEF5F5F5"
			android:background="#55000000"
			android:padding="24dip"
			android:textStyle="bold"
			android:textSize="18sp"
			android:gravity="center"/>
	</FrameLayout>

</RelativeLayout>
