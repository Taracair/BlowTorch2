  <triggers />
  <timers />
  <plugins>
  	 <plugin name="button_window" id="10">
  	 	<windows>
  	 		<window name="button_window" id="10203" script="buttonwindow">
  	 			<layoutGroup target="normal">
  	 				<layout orientation="landscape" height="fill_parent" width="fill_parent" above="40"/>
  	 				<layout orientation="portrait" height="fill_parent" width="fill_parent" above="40"/>
  	 			</layoutGroup>
  	 		</window>
  	 	</windows>
  	 	<options title="Button" summary="Haptic feedback, roundess and other button options.">
  	 		<boolean title="Automatically launch editor" key="auto_launch" summary="Automatically launch the editor on the long press action.">true</boolean>
  	 		<boolean title="Automatically create buttons" key="auto_create" summary="Will add new buttons to emty regions that are long pressed.">true</boolean>
  	 		<boolean title="Show gesture hints" key="show_gesture_hints" summary="Draw swipe arrows, hold (H), and accordion chevrons on buttons.">true</boolean>
  	 		<integer title="Button roundness" key="roundess" summary="Radius of button corners.">6</integer>
  	 		<list title="Haptic feedback on editor launch." key="haptic_edit" summary="Perform haptic feedback when the editor is opened.">
  	 			<value>0</value>
  	 			<item>Auto. Obey System Setting</item>
  	 			<item>Always. Override System Setting</item>
  	 			<item>Off</item>
  	 		</list>
  	 		<list title="Haptic feedback on press." key="haptic_press" summary="Perform haptic feedback when pressed.">
  	 			<value>0</value>
  	 			<item>Auto. Obey System Setting</item>
  	 			<item>Always. Override System Setting</item>
  	 			<item>Off</item>
  	 		</list>
  	 		<list title="Haptic feedback on flip." key="haptic_flip" summary="Perform Haptic feedback when flipped (swipe action).">
  	 			<value>0</value>
  	 			<item>Auto. Obey System Setting</item>
  	 			<item>Always. Override System Setting</item>
  	 			<item>Off</item>
  	 		</list>
  	 	</options>
		<script name="bootstrap" execute="true">
		<![CDATA[
			require("buttonserver")
		]]>
		</script>
		<script name="buttonwindow">
			<![CDATA[
			require("buttonwindow")
		]]>
  		</script>
  		<!--
  		  Fresh-MUD default pad (42×42, ~45 dp grid; alignDefaultButtons pins upper-center).
  		  Compass: tap=walk · outward swipe=look · opposite swipe=open · flip/hold=close.
  		  LOOK (center): tap=look · swipes=look n/s/e/w.
  		  Tutorial chrome lives in the separate "tutorial" set (Starter Tutorial only).
  		-->
   		<buttonsets>
   			<buttonset name="default" setName="default" width="42" height="42" labelSize="12" gridXwidth="45" gridYwidth="45">
     			<button x="23" y="23" label="U" command="up" flipCommand="close u" labelSize="14"
     				holdCommand="close u"
     				swipeUpCommand="look u"
     				swipeDownCommand="open u" />
     			<button x="68" y="23" label="N" command="north" flipCommand="close n" labelSize="14"
     				holdCommand="close n"
     				swipeUpCommand="look n"
     				swipeDownCommand="open n" />
     			<button x="113" y="23" label="INV" command="inventory" labelSize="11" />
     			<button x="23" y="68" label="W" command="west" flipCommand="close w" labelSize="14"
     				holdCommand="close w"
     				swipeLeftCommand="look w"
     				swipeRightCommand="open w" />
     			<button x="68" y="68" label="LOOK" command="look" labelSize="11"
     				swipeUpCommand="look n"
     				swipeDownCommand="look s"
     				swipeLeftCommand="look w"
     				swipeRightCommand="look e" />
     			<button x="113" y="68" label="E" command="east" flipCommand="close e" labelSize="14"
     				holdCommand="close e"
     				swipeRightCommand="look e"
     				swipeLeftCommand="open e" />
     			<button x="23" y="113" label="D" command="down" flipCommand="close d" labelSize="14"
     				holdCommand="close d"
     				swipeDownCommand="look d"
     				swipeUpCommand="open d" />
     			<button x="68" y="113" label="S" command="south" flipCommand="close s" labelSize="14"
     				holdCommand="close s"
     				swipeDownCommand="look s"
     				swipeUpCommand="open s" />
     			<button x="113" y="113" label="SCORE" command="score" labelSize="10" />
     			<button x="23" y="158" label="GET" command="get all" labelSize="11" />
     			<button x="68" y="158" label="WHO" command="who" labelSize="11" />
     			<button x="113" y="158" label="EXITS" command="exits" labelSize="10" />
     			<button x="23" y="203" label="EQ" command="equipment" labelSize="11" />
     			<button x="68" y="203" label="MAP" command=".map toggle" labelSize="11"
     				holdCommand=".map open"
     				flipCommand=".map close" />
     			<button x="113" y="203" label="CLEAR" command=".clearbuttons" labelSize="10" />
</buttonset>
   			<buttonset name="tutorial" setName="tutorial" width="42" height="42" labelSize="12" gridXwidth="45" gridYwidth="45">
     			<button x="23" y="23" label="PREV" command=".tutorial prev" labelSize="11" />
     			<button x="68" y="23" label="NEXT" command=".tutorial next" labelSize="11" />
     			<button x="113" y="23" label="TOPICS" command=".tutorial topics" labelSize="10" />
     			<button x="23" y="68" label="START" command=".tutorial start" labelSize="11" />
     			<button x="68" y="68" label="SWIPE" command=".tutorial buttons_swipe" labelSize="11"
     				swipeUpCommand=".note Swipe UP teaches a directional gesture."
     				swipeDownCommand=".note Swipe DOWN teaches a directional gesture."
     				swipeLeftCommand=".note Swipe LEFT teaches a directional gesture."
     				swipeRightCommand=".note Swipe RIGHT teaches a directional gesture." />
     			<button x="113" y="68" label="HOLD" command=".tutorial buttons_hold" labelSize="11"
     				holdCommand=".note Hold fired: secondary command." />
     			<button x="23" y="113" label="N" command="north" labelSize="14"
     				holdCommand=".note Hold on movement buttons also teaches HOLD."
     				swipeUpCommand=".tutorial buttons_swipe" />
     			<button x="68" y="113" label="S" command="south" labelSize="14"
     				holdCommand=".note Hold on movement buttons also teaches HOLD."
     				swipeDownCommand=".tutorial buttons_swipe" />
     			<button x="113" y="113" label="E" command="east" labelSize="14"
     				holdCommand=".note Hold on movement buttons also teaches HOLD."
     				swipeRightCommand=".tutorial buttons_swipe" />
     			<button x="23" y="158" label="W" command="west" labelSize="14"
     				holdCommand=".note Hold on movement buttons also teaches HOLD."
     				swipeLeftCommand=".tutorial buttons_swipe" />
     			<button x="68" y="158" label="LOOK" command="look" labelSize="11" />
     			<button x="113" y="158" label="DEF" command=".loadset default" labelSize="11" />
     			<button x="23" y="203" label="ACC" command=".tutorial buttons_accordion" labelSize="11" />
     			<button x="68" y="203" label="CLEAR" command=".clearbuttons" labelSize="11" />
</buttonset>
			<selected>default</selected>
  		</buttonsets>
	</plugin>
