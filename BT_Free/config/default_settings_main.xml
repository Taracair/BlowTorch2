      <button xPos="23" yPos="23" label="START" command=".tutorial start" moveMethod="2" labelSize="12" />
      <button xPos="68" yPos="23" label="TOPICS" command=".tutorial topics" moveMethod="2" labelSize="12" />
      <button xPos="113" yPos="23" label="SWIPE" command=".tutorial buttons_swipe" moveMethod="2" labelSize="12" />
